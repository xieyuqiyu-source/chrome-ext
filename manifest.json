{
  "manifest_version": 3,
  "name": "我的笔记",
  "version": "1.0.1",
  "description": "一个轻量、专注、可随 Chrome 账号同步的侧边栏笔记扩展。",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "打开笔记侧边栏"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
