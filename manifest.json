{
  "manifest_version": 3,
  "name": "我的笔记扩展",
  "version": "1.0.0",
  "description": "优雅的侧边栏笔记管理扩展",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_title": "打开笔记侧边栏"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
